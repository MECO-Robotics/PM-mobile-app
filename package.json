{
  "name": "meco-mission-control-mobile",
  "version": "1.0.0",
  "main": "index.ts",
  "engines": {
    "node": ">=20 <24"
  },
  "scripts": {
    "postinstall": "node scripts/patch-freeport-async.js",
    "sim:reset": "node scripts/reset-ios-sim.js",
    "preios": "node scripts/reset-ios-sim.js",
    "verify": "npm run verify:core && npm run verify:bootstrap-contract",
    "verify:core": "npm run lint && npm run test && npm run test:role-permissions && npm run typecheck",
    "dev": "bash ./script/build_and_run.sh --android",
    "start": "expo start",
    "android": "bash ./script/build_and_run.sh --android",
    "ios": "expo start --ios --localhost --port 8081",
    "lint": "eslint .",
    "test": "jest --runInBand",
    "test:role-permissions": "node --test scripts/role-permissions.test.mjs",
    "typecheck": "tsc --noEmit",
    "verify:bootstrap-contract": "node scripts/verify-bootstrap-contract.mjs"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "expo": "~54.0.34",
    "expo-auth-session": "~7.0.11",
    "expo-crypto": "~15.0.9",
    "expo-image-picker": "~17.0.11",
    "expo-localization": "~17.0.8",
    "expo-notifications": "^0.32.17",
    "expo-screen-orientation": "~9.0.9",
    "expo-status-bar": "~3.0.9",
    "expo-web-browser": "~15.0.11",
    "react": "19.1.0",
    "react-native": "0.81.5"
  },
  "devDependencies": {
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.1.0",
    "eslint": "^9.39.4",
    "eslint-config-expo": "~10.0.0",
    "jest-expo": "~54.0.17",
    "react-test-renderer": "^19.1.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
