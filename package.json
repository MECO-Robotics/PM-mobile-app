{
  "name": "meco-mission-control-mobile",
  "version": "1.0.0",
  "main": "index.ts",
  "engines": {
    "node": ">=20 <24"
  },
  "scripts": {
    "postinstall": "node scripts/patch-freeport-async.js",
    "sim:reset": "node scripts/reset-ios-sim.js",
    "preios": "node scripts/reset-ios-sim.js",
    "dev": "bash ./script/build_and_run.sh --android",
    "start": "expo start",
    "android": "bash ./script/build_and_run.sh --android",
    "ios": "expo start --ios --localhost --port 8081",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "expo": "~54.0.33",
    "expo-auth-session": "~7.0.11",
    "expo-crypto": "~15.0.9",
    "expo-localization": "~17.0.8",
    "expo-notifications": "~0.32.17",
    "expo-screen-orientation": "~9.0.9",
    "expo-secure-store": "~15.0.8",
    "expo-status-bar": "~3.0.9",
    "expo-web-browser": "~15.0.11",
    "react": "19.1.0",
    "react-native": "0.81.5"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "eslint": "^9.39.4",
    "eslint-config-expo": "^55.0.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
