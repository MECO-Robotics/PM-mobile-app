{
  "name": "meco-mobile",
  "version": "1.0.0",
  "main": "index.ts",
  "engines": {
    "node": ">=20 <24"
  },
  "scripts": {
    "postinstall": "node scripts/patch-freeport-async.js",
    "sim:reset": "node scripts/reset-ios-sim.js",
    "preios": "node scripts/reset-ios-sim.js",
    "dev": "powershell -ExecutionPolicy Bypass -File ./script/build_and_run.ps1 --android",
    "start": "expo start",
    "android": "powershell -ExecutionPolicy Bypass -File ./script/build_and_run.ps1 --android",
    "ios": "expo start --ios --localhost --port 8081",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "expo": "~54.0.33",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-native": "0.81.5"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
